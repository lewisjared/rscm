#!/usr/bin/env bash

# Deactivate any leaked conda/pixi environments
unset CONDA_PREFIX

# Activate the uv-managed virtual environment
# Creates the venv if it doesn't exist
if [ ! -d ".venv" ]; then
    uv venv
fi

# Use direnv's built-in venv activation
VIRTUAL_ENV="$(pwd)/.venv"
export VIRTUAL_ENV
PATH_add "$VIRTUAL_ENV/bin"

# Point PyO3 to the correct Python
export PYO3_PYTHON="$VIRTUAL_ENV/bin/python"
